# ==============================================================================
# .gitignore - Projet Full Stack (Angular + Node.js/Express + MongoDB + Docker)
# ==============================================================================

# ------------------------------------------------------------------------------
# Dépendances (Node.js / npm) - jamais versionnées, réinstallées via package.json
# ------------------------------------------------------------------------------
node_modules/
**/node_modules/
jspm_packages/

# ------------------------------------------------------------------------------
# Variables d'environnement et fichiers sensibles (secrets, mots de passe, clés)
# ------------------------------------------------------------------------------
.env
.env.*
.env.local
.env.development.local
.env.production.local
!.env.example
*.pem
*.key

# ------------------------------------------------------------------------------
# Fichiers de build / distribution (générés à la compilation)
# ------------------------------------------------------------------------------
dist/
**/dist/
build/
out-tsc/
tmp/

# ------------------------------------------------------------------------------
# Fichiers générés par Angular (cache et sorties du CLI)
# ------------------------------------------------------------------------------
.sass-cache/
.angular/
.angular/cache/
/connect.lock
/coverage/
/libpeerconnection.log
*.ngfactory.ts
*.ngstyle.ts

# ------------------------------------------------------------------------------
# Logs et rapports de diagnostic
# ------------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ------------------------------------------------------------------------------
# Cache npm / yarn / outils
# ------------------------------------------------------------------------------
.npm/
.eslintcache
.cache/
.parcel-cache/
*.tsbuildinfo

# ------------------------------------------------------------------------------
# Fichiers de tests et couverture
# ------------------------------------------------------------------------------
coverage/
.nyc_output/

# ------------------------------------------------------------------------------
# Fichiers temporaires
# ------------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.old
*~
*.swp
*.swo

# ------------------------------------------------------------------------------
# Éditeur / IDE : VS Code (on garde le partage de config utile de l'équipe)
# ------------------------------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/
*.code-workspace

# JetBrains (IntelliJ / WebStorm) au cas où
.idea/
*.iml

# ------------------------------------------------------------------------------
# Système d'exploitation : Windows
# ------------------------------------------------------------------------------
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ------------------------------------------------------------------------------
# Système d'exploitation : macOS
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ------------------------------------------------------------------------------
# Docker : fichiers temporaires et de surcharge locale
# (on conserve Dockerfile et docker-compose.yml versionnés)
# ------------------------------------------------------------------------------
docker-compose.override.yml
*.env.docker


# ------------------------------------------------------------------------------
# MongoDB : données locales éventuelles (dumps, base locale)
# ------------------------------------------------------------------------------
data/db/
*.mongodb

# ------------------------------------------------------------------------------
# Divers
# ------------------------------------------------------------------------------
*.zip
*.tar.gz
.env.local
